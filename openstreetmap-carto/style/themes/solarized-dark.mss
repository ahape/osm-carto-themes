/* Solarized Dark Theme for openstreetmap-carto */

/* Background */
@land-color: #002b36;

/* Water */
@water-color: #073642;
@water-text: #2aa198;
@glacier: #586e75;
@glacier-line: #93a1a1;

/* Landcover */
@forest: #073642;
@park: #073642;
@grass: #073642;
@residential: #002b36;
@industrial: #073642;
@commercial: #002b36;
@farmland: #073642;

/* Roads */
@motorway-fill: #dc322f;
@motorway-casing: #cb4b16;
@trunk-fill: #b58900;
@trunk-casing: #859900;
@primary-fill: #859900;
@primary-casing: #2aa198;
@secondary-fill: #2aa198;
@secondary-casing: #268bd2;
@tertiary-fill: #268bd2;
@tertiary-casing: #6c71c4;

@pedestrian-fill: #586e75;
@pedestrian-casing: #839496;

/* Buildings */
@building-fill: #586e75;
@building-bridge-fill: #657b83;

/* Text */
@building-text-color: #839496;
@address-color: #93a1a1;

/* Amenities */
@hospital-color: #d33682;
@parking: #073642;
